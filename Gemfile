gem 'observer'
gem 'csv'
gem 'base64'
gem 'mutex_m'
gem 'logger'
gem 'ostruct'
gem 'rmagick'
gem 'nokogiri', "~> 1.14.3"
gem 'jekyll'
gem 'jekyll-paginate'
gem 'jekyll-seo-tag'
gem 'jekyll-sitemap'
gem 'jekyll-target-blank'
gem 'jekyll-twitter-plugin'
gem 'jekyll-youtube'
gem 'jekyll-responsive-image'
gem 'jekyll-redirect-from'
gem 'jekyll-sass-converter', "~> 2.0"
gem 'jekyll-dotenv', '~> 0.1.0'
